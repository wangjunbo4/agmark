{
  "name": "agmark",
  "displayName": "AGMark — Annotatable Markdown for AI Agents",
  "description": "Interactive markdown review system. Select text to annotate, one-click send to Claude Code, MCP tools handle the rest.",
  "version": "0.0.1",
  "publisher": "Gtylcara",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wangjunbo4/agmark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "markdown",
    "annotation",
    "review",
    "ai",
    "claude",
    "mcp"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "agmark.markdownPreview",
        "displayName": "AGMark Preview",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "agmark.init",
        "title": "AGMark: Init Annotations",
        "icon": "$(add)"
      },
      {
        "command": "agmark.openPreview",
        "title": "Open AGMark Preview",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "agmark.cleanAnnotations",
        "title": "AGMark: Clean Annotations",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "agmark.openPreview",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "agmark.openPreview",
          "when": "resourceExtname == .md",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "htm": "^3.1.1",
    "markdown-it": "^14.0.0",
    "preact": "^10.19.0"
  }
}
